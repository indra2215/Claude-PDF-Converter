{
  "manifest_version": 3,
  "name": "ISR-CONVERTER - Universal Document Converter",
  "version": "2.1.0",
  "description": "Convert PDFs, Word docs, images, CSV, JSON, XML, and HTML to Markdown on Claude.ai. Smart OCR with quality control. ISR-CONVERTER by Indra.",
  "permissions": ["clipboardRead", "clipboardWrite", "storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://tessdata.projectnaptha.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["lib/pdf.min.js", "lib/tesseract.min.js", "lib/mammoth.min.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.worker.min.js",
        "lib/tesseract.worker.min.js"
      ],
      "matches": ["https://claude.ai/*"]
    }
  ]
}
